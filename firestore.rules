rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Default catch-all deny rule
    match /{document=**} {
      allow read, write: if false;
    }

    // --- REUSABLE SECURITY PRIMITIVES ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().role == role;
    }

    function isAdmin() {
      return hasRole('admin');
    }

    function isAuthority() {
      return hasRole('authority');
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- ENTITY VALIDATION HELPERS ---
    function isValidUserProfile(data) {
      return data.uid == request.auth.uid 
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.email is string && data.email.size() > 0 && data.email.size() <= 120
        && (data.role == 'citizen' || data.role == 'authority' || data.role == 'admin')
        && data.points is number
        && data.badges is list;
    }

    function isValidIssue(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() <= 150
        && data.description is string && data.description.size() > 0 && data.description.size() <= 2000
        && data.category is string && data.category.size() <= 100
        && (data.severity == 'Low' || data.severity == 'Medium' || data.severity == 'High' || data.severity == 'Critical')
        && (data.status == 'Reported' || data.status == 'Under Review' || data.status == 'Assigned' || data.status == 'In Progress' || data.status == 'Resolved' || data.status == 'Rejected')
        && data.latitude is number && data.longitude is number
        && data.address is string
        && data.reporterId is string
        && data.reporterName is string
        && data.verificationCount is number
        && data.verifications is list;
    }

    // --- COLLECTION MATCH BLOCKS ---

    // Users Collection
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId && isValidUserProfile(request.resource.data);
      // Citizens can only change non-role fields like points and badges if they earn them, 
      // but to be secure, block citizens from changing roles, and allow admins full privileges.
      allow update: if isSignedIn() && (
        isAdmin() || 
        (isOwner(userId) && request.resource.data.role == resource.data.role)
      );
      allow delete: if isAdmin();
    }

    // Issues Collection (Central Tickets)
    match /issues/{issueId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidIssue(request.resource.data);
      
      // Allow updates for reports (citizens upvoting/confirming, editing own issues, or authority resolving)
      allow update: if isSignedIn() && (
        isAdmin() ||
        isAuthority() ||
        request.resource.data.reporterId == request.auth.uid ||
        // Allow upvotes/verifications from other citizens (affects verificationCount/verifications/urgencyVotes/duplicateVotes/invalidVotes keys)
        (request.resource.data.reporterId == resource.data.reporterId)
      );
      allow delete: if isAdmin();

      // Nested Subcollection for Votes (prevents multi-vote exploits)
      match /votes/{voteId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
        allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      }
    }

    // Comments Collection
    match /comments/{commentId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // Status Updates Collection
    match /statusUpdates/{updateId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (isAuthority() || isAdmin() || request.resource.data.updaterName != null);
      allow update, delete: if isAdmin();
    }

    // Chat Messages Collection
    match /chatMessages/{messageId} {
      allow read, write: if isSignedIn() && (
        resource == null || resource.data.userId == request.auth.uid || request.resource.data.userId == request.auth.uid
      );
    }

    // Notifications Collection
    match /notifications/{notificationId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // AI Insights Collection
    match /aiInsights/{insightId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin() || isAuthority();
    }
  }
}
